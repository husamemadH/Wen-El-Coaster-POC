{
  "expo": {
    "name": "Wen El Coaster",
    "slug": "wen-el-coaster",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0F172A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wenelcoaster.app"
    },
    "android": {
      "package": "com.wenelcoaster.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
